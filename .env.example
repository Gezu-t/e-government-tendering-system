# ============================================================
# E-Government Tendering System — Required Environment Variables
# ============================================================
# Copy this file to .env and fill in real values before starting.
#   cp .env.example .env
#
# .env is git-ignored. Never commit real secrets.
# ============================================================

# ── Database ──────────────────────────────────────────────
# MySQL root password used by Docker and all backend services.
# Local Homebrew MySQL default is often 'password'; Docker installs require a strong value.
DB_PASSWORD=change-me-before-running

# ── JWT ───────────────────────────────────────────────────
# Symmetric secret for HS512 token signing and verification.
# Must be shared by user-service (issuer) and all resource services (verifiers).
# Minimum 64 printable ASCII characters (512 bits).
# Generate: openssl rand -base64 64 | tr -d '\n'
JWT_SECRET=change-me-to-a-64-plus-character-random-string-before-running-ok

# ── Bid Sealing ───────────────────────────────────────────
# 256-bit (32-byte) AES master key for envelope encryption of sealed bids.
# Must be exactly 32 bytes, base64-encoded (44 characters with padding).
# Generate: openssl rand -base64 32
SEALING_MASTER_KEY=change-me-base64-32-bytes=

# ── SMTP (notification-service) ───────────────────────────
# Leave blank in environments where email is not needed.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# ── MySQL container (docker-compose only) ─────────────────
# Must match DB_PASSWORD above.
MYSQL_ROOT_PASSWORD=${DB_PASSWORD}
